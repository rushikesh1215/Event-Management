generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EventResponseStatus {
  going
  maybe
  not_going
}

model Event {
  id String @id @default(uuid()) @db.Uuid
  ownerUserId String    @map("owner_user_id")
  title       String
  description String?
  location    String?
  eventDate   DateTime? @map("event_date") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  invite EventInvite?
  rsvps EventResponse[]

  @@index([ownerUserId, createdAt(sort: Desc)], map: "idx_events_owner")
  @@map("events")
}

model EventInvite {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @unique @map("event_id") @db.Uuid
  token     String   @unique

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvps EventResponse[]

  @@map("event_invites")
}

model EventResponse {
  id  String     @id @default(uuid()) @db.Uuid
  eventId String @map("event_id") @db.Uuid
  inviteId        String?    @map("invite_id") @db.Uuid
  name            String
  email           String
  emailNormalized String   @map("email_normalized")
  status EventResponseStatus
  respondedAt     DateTime   @default(now()) @map("responded_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invite EventInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@unique([eventId, emailNormalized])
  @@index([eventId, respondedAt(sort: Desc)], map: "idx_rsvps_event")
  @@map("event_rsvps")
}